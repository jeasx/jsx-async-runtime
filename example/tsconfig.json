{
  "compilerOptions": {
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "esnext",
    "strict": false,
    "types": ["*"],
    "rootDir": "src",
    "outDir": "dist",
    "jsx": "react-jsx",
    "jsxImportSource": "jsx-async-runtime",
    "allowJs": true,
    "checkJs": true
  },
  "include": ["src"]
}
